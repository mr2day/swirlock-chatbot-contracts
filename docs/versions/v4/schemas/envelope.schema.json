{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swirlock.local/contracts/v4/envelope.schema.json",
  "title": "Swirlock v4 WebSocket Envelope",
  "type": "object",
  "required": ["type", "correlationId"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "error": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "details": { "type": "object" }
      }
    }
  }
}
